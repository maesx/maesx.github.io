# MySQL数据库配置示例
# 复制此文件为 .env 并修改配置值

# 是否启用MySQL数据库（true/false）
USE_MYSQL=false

# MySQL连接配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=image_segment_platform
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_CHARSET=utf8mb4

# 连接池配置
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20
MYSQL_POOL_RECYCLE=3600
MYSQL_POOL_TIMEOUT=30

# 调试配置（是否打印SQL语句）
MYSQL_ECHO=false
